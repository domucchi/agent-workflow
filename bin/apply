#!/usr/bin/env bash
set -euo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
start_marker="<!-- agent-workflow:start -->"
end_marker="<!-- agent-workflow:end -->"
tmp_files=()

cleanup() {
  if [ "${#tmp_files[@]}" -gt 0 ]; then
    rm -f "${tmp_files[@]}"
  fi
}

trap cleanup EXIT

tmpfile() {
  local file
  file="$(mktemp)"
  tmp_files+=("$file")
  printf '%s\n' "$file"
}

install_skills() {
  local target="$1"
  mkdir -p "$target"

  for skill_dir in "$root"/skills/*; do
    [ -d "$skill_dir" ] || continue

    local skill
    local link
    skill="$(basename "$skill_dir")"
    link="$target/$skill"

    if [ -L "$link" ]; then
      rm "$link"
    elif [ -e "$link" ]; then
      printf 'Refusing to replace existing non-symlink: %s\n' "$link" >&2
      exit 1
    fi

    ln -s "$skill_dir" "$link"
  done
}

write_block() {
  local fragment="$1"
  local out="$2"

  printf '%s\n' "$start_marker" > "$out"
  cat "$fragment" >> "$out"
  printf '%s\n' "$end_marker" >> "$out"
}

update_router() {
  local file="$1"
  local fragment="$2"
  local dir
  local block
  local next

  dir="$(dirname "$file")"
  mkdir -p "$dir"

  if [ ! -f "$file" ]; then
    : > "$file"
  fi

  block="$(tmpfile)"
  next="$(tmpfile)"
  write_block "$fragment" "$block"

  if grep -qF "$start_marker" "$file"; then
    if ! grep -qF "$end_marker" "$file"; then
      printf 'Found start marker without end marker in %s\n' "$file" >&2
      exit 1
    fi

    awk -v start="$start_marker" -v end="$end_marker" -v block_file="$block" '
      BEGIN {
        while ((getline line < block_file) > 0) {
          block = block line ORS
        }
      }
      $0 == start {
        printf "%s", block
        in_block = 1
        next
      }
      $0 == end {
        in_block = 0
        next
      }
      !in_block {
        print
      }
    ' "$file" > "$next"
  else
    cp "$file" "$file.agent-workflow.bak.$(date +%Y%m%d%H%M%S)"
    {
      cat "$file"
      printf '\n\n'
      cat "$block"
    } > "$next"
  fi

  mv "$next" "$file"
}

install_skills "${CODEX_HOME:-$HOME/.codex}/skills"
install_skills "${CLAUDE_HOME:-$HOME/.claude}/skills"

update_router "${CODEX_HOME:-$HOME/.codex}/AGENTS.md" "$root/routers/codex.md"
update_router "${CLAUDE_HOME:-$HOME/.claude}/CLAUDE.md" "$root/routers/claude.md"

printf 'Applied agent workflow from %s\n' "$root"
