#!/usr/bin/env bash
set -euo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
start_marker="<!-- agent-workflow:start -->"
end_marker="<!-- agent-workflow:end -->"
tmp_files=()

cleanup() {
  if [ "${#tmp_files[@]}" -gt 0 ]; then
    rm -f "${tmp_files[@]}"
  fi
}

trap cleanup EXIT

track_tmp() {
  tmp_files[${#tmp_files[@]}]="$1"
}

canonical_existing_path() {
  local path="$1"
  local dir
  local base

  dir="$(dirname "$path")"
  base="$(basename "$path")"

  if [ -d "$dir" ]; then
    (
      cd "$dir"
      printf '%s/%s\n' "$(pwd -P)" "$base"
    )
  else
    printf '%s\n' "$path"
  fi
}

symlink_target_path() {
  local link="$1"
  local target
  local link_dir

  target="$(readlink "$link")"
  if [ "${target#/}" = "$target" ]; then
    link_dir="$(cd "$(dirname "$link")" && pwd -P)"
    target="$link_dir/$target"
  fi

  canonical_existing_path "$target"
}

preflight_skills() {
  local target="$1"
  mkdir -p "$target"

  for skill_dir in "$root"/skills/*; do
    [ -d "$skill_dir" ] || continue

    local skill
    local link
    local expected
    local actual

    skill="$(basename "$skill_dir")"
    link="$target/$skill"
    expected="$(canonical_existing_path "$skill_dir")"

    if [ -L "$link" ]; then
      actual="$(symlink_target_path "$link")"
      if [ "$actual" != "$expected" ]; then
        printf 'Refusing to replace existing symlink pointing elsewhere: %s -> %s\n' "$link" "$(readlink "$link")" >&2
        exit 1
      fi
    elif [ -e "$link" ]; then
      printf 'Refusing to replace existing non-symlink: %s\n' "$link" >&2
      exit 1
    fi
  done
}

install_skills() {
  local target="$1"
  mkdir -p "$target"

  for skill_dir in "$root"/skills/*; do
    [ -d "$skill_dir" ] || continue

    local skill
    local link
    skill="$(basename "$skill_dir")"
    link="$target/$skill"

    rm -f "$link"
    ln -s "$skill_dir" "$link"
  done
}

write_block() {
  local fragment="$1"
  local out="$2"

  printf '%s\n' "$start_marker" > "$out"
  cat "$fragment" >> "$out"
  printf '%s\n' "$end_marker" >> "$out"
}

update_router() {
  local file="$1"
  local fragment="$2"
  local dir
  local block
  local next

  dir="$(dirname "$file")"
  mkdir -p "$dir"

  if [ ! -f "$file" ]; then
    : > "$file"
  fi

  block="$(mktemp)"
  next="$(mktemp)"
  track_tmp "$block"
  track_tmp "$next"
  write_block "$fragment" "$block"

  if grep -qF "$start_marker" "$file"; then
    if ! grep -qF "$end_marker" "$file"; then
      printf 'Found start marker without end marker in %s\n' "$file" >&2
      exit 1
    fi

    awk -v start="$start_marker" -v end="$end_marker" -v block_file="$block" '
      BEGIN {
        while ((getline line < block_file) > 0) {
          block = block line ORS
        }
      }
      $0 == start {
        printf "%s", block
        in_block = 1
        next
      }
      $0 == end {
        in_block = 0
        next
      }
      !in_block {
        print
      }
    ' "$file" > "$next"
  else
    cp "$file" "$file.agent-workflow.bak.$(date +%Y%m%d%H%M%S)"
    {
      cat "$file"
      printf '\n\n'
      cat "$block"
    } > "$next"
  fi

  mv "$next" "$file"
}

codex_skills="${CODEX_HOME:-$HOME/.codex}/skills"
claude_skills="${CLAUDE_HOME:-$HOME/.claude}/skills"

preflight_skills "$codex_skills"
preflight_skills "$claude_skills"

install_skills "$codex_skills"
install_skills "$claude_skills"

update_router "${CODEX_HOME:-$HOME/.codex}/AGENTS.md" "$root/routers/codex.md"
update_router "${CLAUDE_HOME:-$HOME/.claude}/CLAUDE.md" "$root/routers/claude.md"

printf 'Applied agent workflow from %s\n' "$root"
