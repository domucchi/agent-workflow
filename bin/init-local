#!/usr/bin/env bash
set -euo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
workflow_home="${AGENT_WORKFLOW_HOME:-$HOME/.agent-workflow}"
config_home="${XDG_CONFIG_HOME:-$HOME/.config}/agent-workflow"
notify_template="$root/templates/NOTIFY.pushover.md"
notify_file="$workflow_home/NOTIFY.md"
env_file="$config_home/pushover.env"
notify_bin="$workflow_home/bin/agent-notify"
notify_src="$root/bin/agent-notify"
lease_bin="$workflow_home/bin/agent-lease"
lease_src="$root/bin/agent-lease"

ensure_executable() {
  local path="$1"
  if [ ! -x "$path" ]; then
    chmod +x "$path" 2>/dev/null || {
      printf 'Refusing to install non-executable %s\n' "$path" >&2
      exit 1
    }
  fi
}

ensure_symlink() {
  local link="$1"
  local target="$2"
  local current

  if [ -L "$link" ]; then
    current="$(readlink "$link")"
    if [ "$current" = "$target" ]; then
      printf 'Exists %s -> %s\n' "$link" "$current"
    else
      ln -sfn "$target" "$link"
      printf 'Updated %s -> %s\n' "$link" "$target"
    fi
  elif [ -e "$link" ]; then
    printf 'Refusing to overwrite non-symlink %s\n' "$link" >&2
    exit 1
  else
    ln -s "$target" "$link"
    printf 'Created %s -> %s\n' "$link" "$target"
  fi
}

mkdir -p "$workflow_home/projects" "$workflow_home/bin" "$config_home"
chmod 700 "$workflow_home" "$workflow_home/projects" "$workflow_home/bin" "$config_home"

ensure_executable "$notify_src"
ensure_executable "$lease_src"

if [ ! -f "$notify_file" ]; then
  cp "$notify_template" "$notify_file"
  chmod 600 "$notify_file"
  printf 'Created %s\n' "$notify_file"
else
  printf 'Exists %s\n' "$notify_file"
fi

if [ ! -f "$env_file" ]; then
  cat > "$env_file" <<'ENV'
# Pushover credentials for agent-workflow notifications.
# Fill these values locally. Do not commit this file.
export PUSHOVER_APP_TOKEN=""
export PUSHOVER_USER_KEY=""
# Optional: target one registered Pushover device.
# export PUSHOVER_DEVICE=""
ENV
  chmod 600 "$env_file"
  printf 'Created %s\n' "$env_file"
else
  chmod 600 "$env_file"
  printf 'Exists %s\n' "$env_file"
fi

ensure_symlink "$notify_bin" "$notify_src"
ensure_symlink "$lease_bin" "$lease_src"

printf '\nNext steps:\n'
printf '1. Edit %s and fill PUSHOVER_APP_TOKEN/PUSHOVER_USER_KEY.\n' "$env_file"
printf '2. Send a test notification: %s "Agent Workflow test"\n' "$notify_bin"
printf '3. Adjust notification preferences in %s.\n' "$notify_file"
